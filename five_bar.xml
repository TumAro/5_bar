    <worldbody>
    <body name="Crank_L" pos="-0.075 0 0.01">
        <geom class="extrusion" size="0.01 0.1 0.01" pos="0 0.1 0"/>
        <joint name="L_cranker_joint" type="hinge" pos="0 0 0" axis="0 0 1" range="-3.14 3.14" limited="true" damping="0.1"/>
        
        <body name="Coupler_L" pos="0 0.2 0.02">
            <geom class="extrusion" size="0.01 0.1 0.01" pos="0 0.1 0"/>
            <joint name="L_coupler_joint" type="hinge" pos="0 0 0" axis="0 0 1" damping="0.1"/>
            
            <body name="E1" pos="0 0.2 0">
                <site name="sL" pos="0 0 0" size="0.006"/>
            </body>
        </body>
    </body>

    <body name="Crank_R" pos="0.075 0 0.01">
        <geom class="extrusion" size="0.01 0.1 0.01" pos="0 0.1 0"/>
        <joint name="R_cranker_joint" type="hinge" pos="0 0 0" axis="0 0 1" range="-3.14 3.14" limited="true" damping="0.1"/>
        
