    <keyframe>
        <key name="init" qpos="0 -0.3844 0 0.3844"/>
    </keyframe>
    
    <actuator>
        <position name="servo_L" joint="L_cranker_joint" ctrlrange="-3.14 3.14" kp="50" />
        <position name="servo_R" joint="R_cranker_joint" ctrlrange="-3.14 3.14" kp="50"/>
    </actuator>
    <equality>
        <connect site1="sL" site2="sR"/>
    </equality>
